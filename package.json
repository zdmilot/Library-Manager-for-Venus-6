{
  "name": "LibraryManagerForVenus6",
  "main": "html/index.html",
  "description": "Library Manager for Venus 6",
  "version": "1.0.0",
  "keywords": [
    "VENUS",
    "Hamilton"
  ],
  "bin": {
    "libmgr": "./cli.js"
  },
  "scripts": {
    "cli": "node cli.js",
    "list-libs": "node cli.js list-libs",
    "help": "node cli.js help",
    "lint": "node --check cli.js lib/shared.js",
    "chm:images:scan": "node scripts/chm-image-placeholders.js scan",
    "chm:images:check": "node scripts/chm-image-placeholders.js check",
    "chm:images:apply": "node scripts/chm-image-placeholders.js apply",
    "chm:images:dry": "node scripts/chm-image-placeholders.js dry-run",
    "chm:images:revert": "node scripts/chm-image-placeholders.js revert"
  },
  "chromium-args": "--disable-logging --enable-logging=stderr --log-level=3 --disable-crash-reporter",
  "window": {
    "title": "Library Manager for Venus 6",
    "icon": "/LibraryManagerForVenus6.png",
    "show": false,
    "toolbar": true,
    "frame": true,
    "width": 1280,
    "height": 800,
    "min_width": 800,
    "min_height": 700
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "diskdb": "^0.1.17",
    "image-size": "^0.9.5",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@mermaid-js/mermaid-cli": "^11.12.0"
  }
}
