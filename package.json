{
  "name": "LibraryManagerForVenus6",
  "main": "html/index.html",
  "description": "Library Manager for Venus 6",
  "version": "1.6.5",
  "license": "Apache-2.0",
  "author": "Zachary Milot",
  "keywords": [
    "VENUS",
    "Hamilton"
  ],
  "bin": {
    "libmgr": "./cli.js"
  },
  "scripts": {
    "cli": "node cli.js",
    "list-libs": "node cli.js list-libs",
    "help": "node cli.js help",
    "lint": "node --check cli.js lib/shared.js"
  },
  "chromium-args": "--disable-logging --enable-logging=stderr --log-level=3 --disable-crash-reporter --default-background-color=002e48",
  "window": {
    "title": "Library Manager",
    "icon": "/LibraryManagerForVenus6.png",
    "show": false,
    "toolbar": true,
    "frame": true,
    "width": 1280,
    "height": 800,
    "min_width": 800,
    "min_height": 700
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "diskdb": "^0.1.17"
  },
  "devDependencies": {
    "@mermaid-js/mermaid-cli": "^11.12.0"
  }
}
